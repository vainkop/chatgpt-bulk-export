{
  "manifest_version": 3,
  "name": "ChatGPT Bulk Export",
  "version": "1.1.0",
  "description": "Bulk export all ChatGPT conversations as JSON, Markdown, or Text",
  "permissions": ["storage", "downloads"],
  "host_permissions": ["https://chatgpt.com/*"],
  "action": {},
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "js": ["content.js"],
      "matches": ["https://chatgpt.com/*"],
      "run_at": "document_idle"
    }
  ]
}
